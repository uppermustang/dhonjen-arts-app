  "framework": null,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "client/dist",
  "rewrites": [
    {
      "source": "/((?!api/|images/|assets/|dhonjenartsLogo\\.png).*)",
      "destination": "/index.html"
    }
  ]
}
